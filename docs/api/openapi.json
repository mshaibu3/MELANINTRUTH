{
  "components": {
    "schemas": {
      "AnalysisJobResponse": {
        "required": [
          "confidence_score",
          "uncertainty_score",
          "lighting_quality_score",
          "capture_quality_score",
          "limitation_warning"
        ],
        "type": "object"
      },
      "ErrorDetail": {
        "properties": {
          "code": {
            "type": "string"
          },
          "details": {
            "type": "object"
          },
          "message": {
            "type": "string"
          }
        },
        "required": [
          "code",
          "message",
          "details"
        ],
        "type": "object"
      },
      "ErrorEnvelope": {
        "properties": {
          "error": {
            "$ref": "#/components/schemas/ErrorDetail"
          }
        },
        "required": [
          "error"
        ],
        "type": "object"
      },
      "RenderResponse": {
        "required": [
          "confidence_score",
          "uncertainty_score",
          "safety_gate_result",
          "render_status",
          "public_render_available",
          "limitation_warning"
        ],
        "type": "object"
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "info": {
    "title": "MelaninTruth AI API",
    "version": "0.3.7"
  },
  "openapi": "3.1.0",
